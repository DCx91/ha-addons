#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
set -e
bashio::log.info "Initialising Unbound DNS add-on..."

# Read options
UNBOUND_VERBOSITY=$(bashio::config 'unbound_verbosity')
LISTEN_PORT=$(bashio::app.port '5335/udp')
DO_IPV6=$(bashio::config 'do_ipv6')
NUM_THREADS=$(bashio::config 'num_threads')
NO_PERSIST_CACHE=$(bashio::config 'no_persist_cache')
CACHE_MIN_TTL=$(bashio::config 'cache_min_ttl')
CACHE_MAX_TTL=$(bashio::config 'cache_max_ttl')

# Cap threads to CPU core count
if bashio::config.has_value 'num_threads'; then
	MAX_THREADS=$(nproc)
	if [ "${NUM_THREADS}" -gt "${MAX_THREADS}" ]; then
		bashio::log.warning "num_threads (${NUM_THREADS}) exceeds available CPU cores (${MAX_THREADS}), capping to ${MAX_THREADS}."
		NUM_THREADS=${MAX_THREADS}
	fi
fi

# Persistent config directory
CONFIG_DIR="/config"
UNBOUND_CONF="${CONFIG_DIR}/unbound.conf"
CONF_D_DIR="${CONFIG_DIR}/conf.d"
ZONES_DIR="${CONFIG_DIR}/zones"
ROOT_KEY="/etc/unbound/root.key"
HINTS_FILE="/etc/unbound/root.hints"

mkdir -p "${CONF_D_DIR}" "${ZONES_DIR}"

# Refresh root hints if older than 7 days
if [ ! -f "${HINTS_FILE}" ] || \
	[ "$(find "${HINTS_FILE}" -mtime +7 | wc -l)" -gt 0 ]; then
		bashio::log.info "Refreshing root hints..."
		curl -sSL "https://www.internic.net/domain/named.root" \
		-o "${HINTS_FILE}" \
		|| bashio::log.warning "Could not refresh root hints; using cached copy."
fi

# Build access-control lines
ACCESS_CONTROL_LINES=""
if bashio::config.has_value 'access_control'; then
    while read -r acl; do
        ACCESS_CONTROL_LINES+="    access-control: ${acl}"$'\n'
    done < <(jq -r '.access_control[]' /data/options.json)
fi

# Generate unbound.conf
bashio::log.info "Generating Unbound configuration..."

cat > "${UNBOUND_CONF}" << EOF
server:
	username: ""
	verbosity: ${UNBOUND_VERBOSITY}
$(bashio::config.has_value 'num_threads' && echo "    num-threads: ${NUM_THREADS}")
$([ "${DO_IPV6}" = "false" ] && echo "    do-ip6: no")

	# Interfaces
	interface: 0.0.0.0
	port: ${LISTEN_PORT}
$([ "${DO_IPV6}" = "true" ] && echo "    interface: ::0")

	# Access control
	access-control: 0.0.0.0/0 refuse
	access-control: ::0/0 refuse
	access-control: 10.0.0.0/8 allow
	access-control: 127.0.0.0/8 allow
	access-control: 172.16.0.0/12 allow
	access-control: 192.168.0.0/16 allow
$([ "${DO_IPV6}" = "true" ] && printf '    access-control: ::1/128 allow\n    access-control: fe80::/10 allow\n    access-control: fd00::/8 allow')
${ACCESS_CONTROL_LINES}

	# DNSSEC
	auto-trust-anchor-file: "${ROOT_KEY}"
	root-hints: "${HINTS_FILE}"

	# Privacy & hardening
	hide-identity: yes
	hide-version: yes
	do-not-query-localhost: no
	private-address: 255.255.255.255/32
	private-address: 203.0.113.0/24
	private-address: 198.51.100.0/24
	private-address: 198.18.0.0/15
	private-address: 192.168.0.0/16
	private-address: 192.0.2.0/24
	private-address: 192.0.0.0/24
	private-address: 169.254.0.0/16
	private-address: 172.16.0.0/12
	private-address: 100.64.0.0/10
	private-address: 10.0.0.0/8
	private-address: 0.0.0.0/8
	private-address: fd00::/8
	private-address: fe80::/10
	private-address: 2001:db8::/32
	private-address: ::ffff:0:0/96

	# Caching
	prefetch: yes
	prefetch-key: yes
	neg-cache-size: 4m
$(bashio::config.has_value 'cache_min_ttl' && echo "    cache-min-ttl: ${CACHE_MIN_TTL}")
$(bashio::config.has_value 'cache_max_ttl' && echo "    cache-max-ttl: ${CACHE_MAX_TTL}")

	# Performance
	so-rcvbuf: 4m
	rrset-cache-size: 256m
	msg-cache-size: 128m
	serve-expired: yes
	outgoing-range: 8192
	num-queries-per-thread: 4096

	# Logging
	use-syslog: no
$([ "${UNBOUND_VERBOSITY}" -ge 3 ] && printf '    log-queries: yes\n    log-replies: yes')

	# Include user-created config files
	include-toplevel: "${CONF_D_DIR}/*.conf"

remote-control:
	control-enable: yes
	control-interface: ${CONFIG_DIR}/unbound.control.sock
	control-use-cert: no

# Hyperlocal
auth-zone:
	name: "."
	master: k.root-servers.net
	master: i.root-servers.net
	fallback-enabled: yes
	for-downstream: no
	for-upstream: yes
	zonefile: "/etc/unbound/root.zone"
EOF

# Apply any custom config
if bashio::config.has_value 'custom_config'; then
    CUSTOM_CONFIG=$(bashio::config 'custom_config')
    bashio::log.info "Applying custom config snippet..."
    {
        echo ""
        echo "# --- Custom config from app options ---"
        echo "${CUSTOM_CONFIG}"
    } >> "${UNBOUND_CONF}"
fi

# Validate configuration
bashio::log.info "Validating configuration..."
if CHECKCONF_OUTPUT=$(unbound-checkconf "${UNBOUND_CONF}" 2>&1); then
    bashio::log.info "Configuration valid!"
else
    bashio::log.fatal "Unbound configuration is invalid."
    echo "${CHECKCONF_OUTPUT}"
    exit 1
fi

log_output() {
    bashio::log.info "$(printf '%-20s: %s' "$1" "$2")"
}

log_output "Port" "${LISTEN_PORT}"
log_output "Verbosity" "${UNBOUND_VERBOSITY}"
log_output "IPv6" "${DO_IPV6}"
log_output "Threads" "$(bashio::config.has_value 'num_threads' && echo "${NUM_THREADS}" || echo '1')"
log_output "Min TTL" "$(bashio::config.has_value 'cache_min_ttl' && echo "${CACHE_MIN_TTL}s" || echo '0s')"
log_output "Max TTL" "$(bashio::config.has_value 'cache_max_ttl' && echo "${CACHE_MAX_TTL}s" || echo '86400s')"
log_output "Cache persistence" "$([ "${NO_PERSIST_CACHE}" = "true" ] && echo 'disabled' || echo 'enabled')"
log_output "Custom config" "$(bashio::config.has_value 'custom_config' && echo 'true' || echo 'false')"

exit 0
