#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
declare exit_code="${1}"
declare signal="${2}"

if [[ "${exit_code}" -ne 0 ]] && [[ "${exit_code}" -ne 256 ]]; then
    bashio::log.error "Unbound exited unexpectedly (exit code ${exit_code}, signal ${signal})."
else
    bashio::log.warning "Unbound exited. Stopping add-on."
fi

bashio::addon.stop
