#!/usr/bin/with-contenv bashio
# shellcheck shell=bash

bashio::log.info "Starting Unbound DNS add-on..."

# Helper for optional config values with defaults
config_or_default() {
    local key="$1" default="$2"
    if bashio::config.has_value "${key}"; then
        bashio::config "${key}"
    else
        echo "${default}"
    fi
}

# Read options
LOG_LEVEL=$(bashio::config 'log_level' | grep -o '^[0-5]')
LISTEN_PORT=$(bashio::config 'listen_port')
DO_IPV6=$(bashio::config 'do_ipv6')
PREFETCH=$(bashio::config 'prefetch')
CUSTOM_CONFIG=$(config_or_default 'custom_config' '')
CACHE_MIN_TTL=$(config_or_default 'cache_min_ttl' '300')
CACHE_MAX_TTL=$(config_or_default 'cache_max_ttl' '86400')
REMOTE=$(config_or_default 'remote' false)

# Cap threads to CPU core count
MAX_THREADS=$(nproc)
NUM_THREADS=$(bashio::config 'num_threads')
if [ "${NUM_THREADS}" -gt "${MAX_THREADS}" ]; then
    bashio::log.warning "num_threads (${NUM_THREADS}) exceeds available CPU cores (${MAX_THREADS}), capping to ${MAX_THREADS}."
    NUM_THREADS=${MAX_THREADS}
fi

# Persistent config directory
CONFIG_DIR="/addon_configs/unbound"
UNBOUND_CONF="${CONFIG_DIR}/unbound.conf"
CONF_D_DIR="${CONFIG_DIR}/conf.d"
ZONES_DIR="${CONFIG_DIR}/zones"
ROOT_KEY="${CONFIG_DIR}/root.key"

mkdir -p "${CONF_D_DIR}" "${ZONES_DIR}"

# If Remote Control enabled, check for required files
if [ "${REMOTE}" = "true" ]; then

    if [ ! -f "${CONFIG_DIR}/unbound_server.key" ] || \
       [ ! -f "${CONFIG_DIR}/unbound_server.pem" ] || \
       [ ! -f "${CONFIG_DIR}/unbound_control.key" ] || \
       [ ! -f "${CONFIG_DIR}/unbound_control.pem" ]; then
        bashio::log.info "Remote control enabled. Keys/certs not found. Setting up..."
        unbound-control-setup
        cp /etc/unbound/unbound_*.key /etc/unbound/unbound_*.pem "${CONFIG_DIR}/"
        chown unbound:unbound "${CONFIG_DIR}"/unbound_*.key "${CONFIG_DIR}"/unbound_*.pem
		chmod 640 "${CONFIG_DIR}"/unbound_*.key "${CONFIG_DIR}"/unbound_*.pem
    else
        bashio::log.info "Remote control enabled. Keys/certs found. Continuing..."
    fi
fi

# Refresh root hints if older than 7 days
HINTS_FILE="/etc/unbound/root.hints"
if [ ! -f "${HINTS_FILE}" ] || \
   [ "$(find "${HINTS_FILE}" -mtime +7 | wc -l)" -gt 0 ]; then
    bashio::log.info "Refreshing root hints..."
    curl -sSL "https://www.internic.net/domain/named.root" \
        -o "${HINTS_FILE}" \
    || bashio::log.warning "Could not refresh root hints; using cached copy."
fi

# Build access-control lines
ACCESS_CONTROL_LINES=""
while read -r acl; do
    ACCESS_CONTROL_LINES+="    access-control: ${acl}"$'\n'
done < <(jq -r '.access_control[]' /data/options.json)

# Copy root key to writable location
if [ ! -f "${ROOT_KEY}" ]; then
    cp /etc/unbound/root.key "${ROOT_KEY}"
fi

# Generate unbound.conf
bashio::log.info "Generating Unbound configuration..."

cat > "${UNBOUND_CONF}" << EOF
server:
    verbosity: ${LOG_LEVEL}
    num-threads: ${NUM_THREADS}

    # Interfaces
    interface: 0.0.0.0
$([ "${DO_IPV6}" = "true" ] && echo "    interface: ::0")
    port: ${LISTEN_PORT}

    # Access control
    access-control: 0.0.0.0/0 refuse
    access-control: ::0/0 refuse
${ACCESS_CONTROL_LINES}

    # DNSSEC
    auto-trust-anchor-file: "${ROOT_KEY}"
    root-hints: "${HINTS_FILE}"

    # Privacy & hardening
    hide-identity: yes
    hide-version: yes
    harden-referral-path: yes
    use-caps-for-id: yes
    do-not-query-localhost: no

    # Caching
    cache-min-ttl: ${CACHE_MIN_TTL}
    cache-max-ttl: ${CACHE_MAX_TTL}
    prefetch: $([ "${PREFETCH}" = "true" ] && echo "yes" || echo "no")
    prefetch-key: yes
    neg-cache-size: 4m

    # Performance
    so-rcvbuf: 1m
    rrset-cache-size: 256m
    msg-cache-size: 128m
    serve-expired: yes

    # IPv6
    do-ip6: $([ "${DO_IPV6}" = "true" ] && echo "yes" || echo "no")

    # Logging
    log-queries: $([ "${LOG_LEVEL}" -ge 3 ] && echo "yes" || echo "no")
    log-replies: $([ "${LOG_LEVEL}" -ge 3 ] && echo "yes" || echo "no")
    logfile: ""
    use-syslog: no

    # Include user-created config files
    include-toplevel: "${CONF_D_DIR}/*.conf"

$([ "${REMOTE}" = "true" ] && cat << REMOTE_EOF
# Remote control
remote-control:
    control-enable: yes
    control-interface: ${CONFIG_DIR}/unbound.control.sock
    server-key-file: "${CONFIG_DIR}/unbound_server.key"
    server-cert-file: "${CONFIG_DIR}/unbound_server.pem"
    control-key-file: "${CONFIG_DIR}/unbound_control.key"
    control-cert-file: "${CONFIG_DIR}/unbound_control.pem"
    bashio::log.info "Remote control enabled."
REMOTE_EOF
)
EOF

# Apply any custom config
if bashio::var.has_value "${CUSTOM_CONFIG}"; then
    bashio::log.info "Applying custom config snippet..."
    echo "" >> "${UNBOUND_CONF}"
    echo "# --- Custom config from addon options ---" >> "${UNBOUND_CONF}"
    echo "${CUSTOM_CONFIG}" >> "${UNBOUND_CONF}"
fi

# Validate configuration
bashio::log.info "Validating configuration..."
if ! unbound-checkconf "${UNBOUND_CONF}"; then
    bashio::log.fatal "Unbound configuration is invalid! Check your options."
    bashio::addon.stop
fi

# Launch Unbound
bashio::log.info "Launching Unbound on port ${LISTEN_PORT}..."
bashio::log.info "Prefetch : ${PREFETCH}"
bashio::log.info "Remote   : ${REMOTE}"
bashio::log.info "Log Level: ${LOG_LEVEL}"
bashio::log.info "IPv6     : ${DO_IPV6}"
bashio::log.info "Threads  : ${NUM_THREADS}"
bashio::log.info "Min TTL  : ${CACHE_MIN_TTL}s"
bashio::log.info "Max TTL  : ${CACHE_MAX_TTL}s"
chown -R unbound:unbound "${CONFIG_DIR}"
exec unbound -d -c "${UNBOUND_CONF}"
